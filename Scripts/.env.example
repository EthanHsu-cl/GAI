# Testbed cookie for authenticated API access
# Copy this file to .env and replace with your own cookie value.
#
# To get your cookie:
# 1. Open the testbed URL in your browser
# 2. Log in / authenticate
# 3. Open DevTools (F12) → Network tab
# 4. Reload the page and click any request to the testbed
# 5. Copy the full "Cookie" header value from the request headers
#
# Example:
# TESTBED_COOKIE=session_id=abc123; auth_token=xyz789
TESTBED_COOKIE=
